# Klucz Google Maps — wymagany, żeby mapa (provider="google") renderowała się
# w realnym buildzie (bez niego mapa jest szara na Androidzie).
# Pobierz w Google Cloud Console (Maps SDK for Android + Maps SDK for iOS),
# zalecane: ogranicz klucz do package name / bundle id aplikacji.
# Expo CLI automatycznie wczytuje ten plik przy prebuild/run.
GOOGLE_MAPS_API_KEY=
