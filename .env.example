# Blackout — przegląd zmiennych środowiskowych.
#
# Każdy pakiet ma własny plik .env (skopiuj odpowiedni .env.example i uzupełnij):
#   backend/.env   — zob. backend/.env.example
#   frontend/.env  — zob. frontend/.env.example
#   cms/.env       — zob. cms/.env.example
#
# Poniżej skrót najważniejszych zmiennych. NIE commituj prawdziwych .env do repo.

# === backend ===
# Połączenie do PostgreSQL.
DATABASE_URL="postgresql://admin:admin@localhost:5433/blackout_game?schema=public"
# Sekret JWT — WYMAGANY, serwer nie wystartuje bez niego.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="zmien-mnie-na-silny-losowy-sekret"
# Dozwolone originy CORS (lista po przecinku). Puste = tryb otwarty (tylko dev).
# CORS_ORIGIN=https://cms.blackout.example,https://app.blackout.example
# PORT=3000
# NODE_ENV=production

# === cms (Vite) ===
# Bazowy adres API backendu.
VITE_API_BASE=http://localhost:3000/api

# === frontend (Expo) ===
# Klucz Google Maps (mapa na Androidzie). Szczegóły w frontend/.env.example.
GOOGLE_MAPS_API_KEY=
