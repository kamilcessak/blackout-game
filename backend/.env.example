# Połączenie do bazy PostgreSQL
DATABASE_URL="postgresql://admin:admin@localhost:5433/blackout_game?schema=public"

# Sekret do podpisywania tokenów JWT — WYMAGANY, serwer nie wystartuje bez niego.
# Wygeneruj silny sekret, np.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="zmien-mnie-na-silny-losowy-sekret"

# Port serwera (opcjonalny, domyślnie 3000)
# PORT=3000

# Dozwolone originy CORS — lista po przecinku. Pozostaw puste w dev (tryb otwarty),
# w produkcji ustaw konkretne adresy frontu/CMS, np.:
#   CORS_ORIGIN=https://cms.blackout.example,https://app.blackout.example
# CORS_ORIGIN=

# Ustaw na "production" w środowisku produkcyjnym — wyłącza deweloperskie cheaty
# (np. /api/map/locations/spawn).
# NODE_ENV=production
