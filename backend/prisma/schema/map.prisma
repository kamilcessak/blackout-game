model Location {
  id          Int     @id @default(autoincrement())
  name        String
  type        String
  latitude    Float
  longitude   Float
  description String?
  osmId       String?  @unique

  createdAt   DateTime @default(now())
  cooldowns   UserLocationCooldown[]
  airdropItems AirdropItem[]
}

model AirdropItem {
  id         Int      @id @default(autoincrement())
  locationId Int
  itemId     Int
  quantity   Int      @default(1)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  item       Item     @relation(fields: [itemId], references: [id])

  @@unique([locationId, itemId])
}

model UserLocationCooldown {
  id         Int      @id @default(autoincrement())
  userId     Int
  locationId Int
  user       User     @relation(fields: [userId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])
  lootedAt   DateTime @default(now())

  @@unique([userId, locationId])
}

model GameConfig {
  id              Int @id @default(1)
  xpPerLoot       Int @default(10)
  baseStorage     Int @default(10)
  storagePerLevel Int @default(5)
}