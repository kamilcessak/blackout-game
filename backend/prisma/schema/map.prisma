model Location {
  id          Int     @id @default(autoincrement())
  name        String
  type        String
  latitude    Float
  longitude   Float
  description String?
  osmId       String?  @unique

  createdAt   DateTime @default(now())
  cooldowns   UserLocationCooldown[]
}

model UserLocationCooldown {
  id         Int      @id @default(autoincrement())
  userId     Int
  locationId Int
  user       User     @relation(fields: [userId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])
  lootedAt   DateTime @default(now())

  @@unique([userId, locationId])
}