model Item {
  id          Int    @id @default(autoincrement())
  name        String
  type        String // eg. FOOD, WATER, MEDKIT
  inventory   InventoryItem[]
  airdropItems AirdropItem[]
}

model InventoryItem {
  id       Int  @id @default(autoincrement())
  user     User @relation(fields: [userId], references: [id])
  userId   Int
  item     Item @relation(fields: [itemId], references: [id])
  itemId   Int
  quantity Int @default(1)

  @@unique([userId, itemId])
}

// Recepty craftingu trzymane w bazie zamiast zahardkodowane w kodzie kontrolera/ekranu.
model Recipe {
  id          Int                @id @default(autoincrement())
  name        String             @unique // nazwa przedmiotu wynikowego
  type        String // typ przedmiotu wynikowego (np. WATER, MEDKIT)
  ingredients RecipeIngredient[]
}

model RecipeIngredient {
  id        Int    @id @default(autoincrement())
  recipe    Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId  Int
  itemName  String // składnik identyfikowany po nazwie (Item.name)
  quantity  Int    @default(1)

  @@unique([recipeId, itemName])
}